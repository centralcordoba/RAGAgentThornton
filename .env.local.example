# =============================================================================
# RegWatch AI — Local Development Environment
# Copy to .env.local: cp .env.local.example .env.local
# Then fill in Azure-specific values
# =============================================================================

# --- Azure OpenAI (required for RAG/chat) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_GPT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-06-01

# --- Azure AI Search (required for RAG/chat) ---
AZURE_SEARCH_ENDPOINT=https://your-resource.search.windows.net
AZURE_SEARCH_API_KEY=your-key-here
AZURE_SEARCH_INDEX_NAME=regulatory-documents

# --- Azure Service Bus (optional for local — can use in-memory queue) ---
SERVICE_BUS_CONNECTION_STRING=

# --- Local services (set by docker-compose, override only if needed) ---
# DATABASE_URL=postgresql://regwatch:regwatch_dev@localhost:5432/regwatch_db
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=neo4j_dev_password
# REDIS_URL=redis://localhost:6379

# --- App ---
PORT=3000
WEB_PORT=3001
LOG_LEVEL=debug
JWT_SECRET=dev-secret-change-in-production
