# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_GPT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-06-01

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<your-resource>.search.windows.net
AZURE_SEARCH_API_KEY=<your-key>
AZURE_SEARCH_INDEX_NAME=regulatory-documents

# PostgreSQL
DATABASE_URL=postgresql://regwatch:regwatch_dev@localhost:5432/regwatch_db

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_dev_password

# Redis
REDIS_URL=redis://localhost:6379

# Azure Service Bus
SERVICE_BUS_CONNECTION_STRING=<your-connection-string>
SERVICE_BUS_QUEUE_NAME=regulatory-changes

# Azure Key Vault
KEY_VAULT_URL=https://<your-vault>.vault.azure.net

# Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=<your-connection-string>

# Azure Communication Services (Email)
ACS_CONNECTION_STRING=<your-connection-string>
ACS_SENDER_EMAIL=regwatch@<your-domain>.azurecomm.net

# App
NODE_ENV=development
PORT=3000
WEB_PORT=3001
LOG_LEVEL=debug
JWT_SECRET=dev-secret-change-in-production
